{
    "name": "ScoutmasterBucky",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npm run build-dist && npm run build-sitemap && npm run verify-internal-links",
        "build-dist": "astro build",
        "build-sitemap": "node build-sitemap.mjs",
        "now": "npm run build && npm run preview",
        "reinstall": "rm -rf node_modules package-lock.json && npm install",
        "start": "astro dev --open --host",
        "start-windows": "npm ci && npm run start",
        "verify-data": "node validate-data.mjs",
        "verify-external-links": "checklinks -a",
        "verify-internal-links": "check-html-links dist/ 2>&1 > /dev/null | ( ! grep --context=1000 '❌' )"
    },
    "engines": {
        "node": ">= 20.0.0"
    },
    "devDependencies": {
        "@johnwargo/link-checker": "^0.0.9",
        "@literals/rollup-plugin-html-css-minifier": "^3.0.1",
        "@rollup/plugin-yaml": "^4.1.2",
        "@types/js-yaml": "^4.0.9",
        "@types/luxon": "^3.7.1",
        "@types/papaparse": "^5.5.2",
        "ajv": "^8.18.0",
        "astro": "^5.17.2",
        "check-html-links": "^0.2.4",
        "fudgel": "^3.2.0",
        "glob": "^13.0.3",
        "glob-to-regexp": "^0.4.1",
        "got": "^14.6.6",
        "js-yaml": "^4.1.1",
        "json-stable-stringify": "^1.3.0",
        "linkedom": "^0.18.12",
        "luxon": "^3.7.2",
        "neodoc": "^2.0.2",
        "papaparse": "^5.5.3",
        "pdfjs-dist": "^5.4.624",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "^5.9"
    }
}
