---
interface Props {
    align?: 'left' | 'right' | 'center';
    small?: boolean;
}

const { align, small } = Astro.props;
const alignClass = ['left', 'right', 'center'].includes(align) ? align : 'none';
const sizeClass = `scaled ${small ? 'small' : ''}`;
---

{
    align === 'none' && (
        <div class={sizeClass}>
            <slot />
        </div>
    )
}
{
    align !== 'none' && (
        <div class={align}>
            <div class={sizeClass}>
                <slot />
            </div>
        </div>
    )
}

<style>
    .scaled {
        padding: 9px;
        max-width: 250px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        flex-direction: column;
    }

    .small {
        max-width: 125px;
    }

    .left,
    .right,
    .center {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .left {
        float: left;
    }

    .right {
        float: right;
    }

    .center {
        width: 100%;
        display: flex;
    }

    @media (min-width: 768.0001px) and (max-width: 1024px) {
        .scaled {
            /* 250 / 1024 = 24.4% */
            width: 24.4vw;
        }

        .scaled.small {
            /* 125 / 1024 = 12.2% */
            width: 12.2vw;
        }
    }

    @media (min-width: 480.0001px) and (max-width: 768px) {
        .scaled {
            /* 250 / 768 = 32.6% */
            width: 32.6vw;
        }

        .scaled.small {
            /* 125 / 768 = 16.3% */
            width: 16.3vw;
        }
    }

    @media (max-width: 480px) {
        .scaled {
            width: min(100%, 250px);
        }

        .scaled.small {
            width: min(100%, 125px);
        }

        .left,
        .right {
            width: 100%;
            float: none;
        }
    }
</style>
